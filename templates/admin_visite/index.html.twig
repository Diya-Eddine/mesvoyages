{% extends 'base.html.twig' %}
{% block title %}Visite index{% endblock %}
{% block body %}
    <h1>Visite index</h1>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Ville</th>
                <th>Pays</th>
                <th>Note</th>
                <th>Temp MIN</th>
                <th>Temp MAX</th>
                <th>Date</th>
                <th>Avis</th>
                <th>Photo</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for visite in visites %}
            <tr>
                <td>{{ visite.id }}</td>
                <td>{{ visite.ville }}</td>
                <td>{{ visite.pays }}</td>
                <td>{{ visite.note }}</td>
                <td>{{ visite.tempmin }}</td>
                <td>{{ visite.tempmax }}</td>
                <td>{{ visite.datecreationstring }}</td>
                <td>{{ visite.avis }}</td>
                <td>{{ visite.photo }}</td>
                <td>
                    <a href="{{ path('app_admin_visite_show', {'id': visite.id}) }}">show</a>
                    <a href="{{ path('app_admin_visite_edit', {'id': visite.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('app_admin_visite_new') }}">Create new</a>
{% endblock %}