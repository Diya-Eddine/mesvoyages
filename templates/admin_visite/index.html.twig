{% extends 'base.html.twig' %}
{% block title %}Gestion des voyages{% endblock %}
{% block body %}
    <h1>Gestion des voyages</h1>

    <p class="text-end">
        <a href="{{ path('app_admin_visite_new') }}" class="btn btn-primary">
            Ajouter une nouvelle visite
        </a>
    </p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Ville</th>
                <th>Pays</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for visite in visites %}
            <tr>
                <td>
                    <h5 class="text-primary">{{ visite.ville }}</h5>
                </td>
                <td>{{ visite.pays }}</td>
                <td>{{ visite.datecreationstring }}</td>
                <td>
                    <a href="{{ path('app_admin_visite_edit', {'id': visite.id}) }}" 
                       class="btn btn-secondary">Editer</a>
                    <a href="{{ path('app_admin_visite_delete', {'id': visite.id}) }}" 
                       class="btn btn-danger"
                       onclick="return confirm('Etes-vous sûr de vouloir supprimer {{ visite.ville }} ?')">Supprimer</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune visite trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}