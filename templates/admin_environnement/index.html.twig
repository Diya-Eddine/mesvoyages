{% extends 'base.html.twig' %}

{% block title %}Environnement index{% endblock %}

{% block body %}
    <h1>Environnement index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for environnement in environnements %}
            <tr>
                <td>{{ environnement.id }}</td>
                <td>{{ environnement.nom }}</td>
                <td>
                    <a href="{{ path('app_admin_environnement_show', {'id': environnement.id}) }}">show</a>
                    <a href="{{ path('app_admin_environnement_edit', {'id': environnement.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin_environnement_new') }}">Create new</a>
{% endblock %}
